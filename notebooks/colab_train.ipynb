    "# ── CELL 7: EGITIM ────────────────────────────────────────────────────────────\n",
    "# Session yenilenince bu cell'i calistir — Drive'daki checkpoint'ten devam eder\n",
    "import os\n",
    "\n",
    "CKPT_DIR   = \"/content/drive/MyDrive/sar_fusion_runs\"\n",
    "DATA_ROOT  = \"/content/data/M4-SAR/M4-SAR\"  # Cell 4 calistirildiysa uzerine yazar\n",
    "REPO_DIR   = \"/content/sar-optical-fusion\"\n",
    "\n",
    "# DATA_ROOT'u Cell 4 ciktisina gore guncelle (manual override gerekirse buraya yaz)\n",
    "# DATA_ROOT = \"/content/data/M4-SAR/M4-SAR\"  # <-- farkli cikarsa degistir\n",
    "\n",
    "os.makedirs(CKPT_DIR, exist_ok=True)\n",
    "%cd {REPO_DIR}\n",
    "\n",
    "# Drive'da checkpoint var mi? Varsa resume et\n",
    "best_ckpt = os.path.join(CKPT_DIR, \"best.pt\")\n",
    "resume_arg = f\"--resume {best_ckpt}\" if os.path.exists(best_ckpt) else \"\"\n",
    "\n",
    "if resume_arg:\n",
    "    print(f\"[RESUME] {best_ckpt} uzerinden devam ediliyor\")\n",
    "else:\n",
    "    print(\"[FRESH] Sifirdan basliyor\")\n",
    "\n",
    "!python -m src.train \\\n",
    "    --config configs/kaggle_p100.yaml \\\n",
    "    --data_root \"{DATA_ROOT}\" \\\n",
    "    --output \"{CKPT_DIR}\" \\\n",
    "    {resume_arg}"
   ]
